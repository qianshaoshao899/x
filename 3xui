#!/bin/bash
set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${GREEN}=== 3x-ui + Nginx 一键部署（稳定版） ===${NC}"

[ "$EUID" -ne 0 ] && echo -e "${RED}请用 root 运行${NC}" && exit 1

input_default() {
    local prompt="$1"
    local default="$2"
    local input
    read -p "$prompt [默认: $default]: " input
    echo "${input:-$default}"
}

DOMAIN=$(input_default "域名" "example.com")
EMAIL=$(input_default "邮箱" "admin@$DOMAIN")
PANEL_PORT=$(input_default "端口" "33130")
PANEL_PATH=$(input_default "路径(留空自动生成)" "")

[ -z "$PANEL_PATH" ] && PANEL_PATH=$(openssl rand -hex 8)

USERNAME=$(input_default "用户名" "admin")
PASSWORD=$(input_default "密码" "123456")

SSL_DIR="/etc/nginx/ssl"

echo "域名: $DOMAIN"
echo "端口: $PANEL_PORT"
echo "路径: $PANEL_PATH"

read -p "继续? (y/n): " CONFIRM
[ "$CONFIRM" != "y" ] && exit

apt update
apt install -y curl socat nginx ufw dnsutils openssl

IP=$(curl -s ifconfig.me)
DOMAIN_IP=$(dig +short $DOMAIN | head -n1)

[ "$IP" != "$DOMAIN_IP" ] && echo "域名未解析" && exit

rm -rf ~/.acme.sh
curl https://get.acme.sh | sh -s email=$EMAIL
source ~/.bashrc
ACME="$HOME/.acme.sh/acme.sh"

systemctl stop nginx || true

$ACME --issue -d $DOMAIN --standalone --ecc --force

mkdir -p $SSL_DIR

$ACME --install-cert -d $DOMAIN --ecc \
--key-file $SSL_DIR/panel.key \
--fullchain-file $SSL_DIR/panel.crt \
--reloadcmd "systemctl reload nginx"

cat > /etc/nginx/conf.d/panel.conf <<EOF
server {
    listen 80;
    server_name $DOMAIN;
    return 301 https://\$host\$request_uri;
}

server {
    listen 443 ssl;
    server_name $DOMAIN;

    ssl_certificate $SSL_DIR/panel.crt;
    ssl_certificate_key $SSL_DIR/panel.key;

    location /$PANEL_PATH/ {
        proxy_pass http://127.0.0.1:$PANEL_PORT/;
        proxy_set_header Host \$host;
    }
}
EOF

nginx -t
systemctl start nginx

bash <(curl -Ls https://raw.githubusercontent.com/mhsanaei/3x-ui/master/install.sh) <<< "y"

x-ui setting -reset
x-ui setting -username "$USERNAME"
x-ui setting -password "$PASSWORD"
x-ui setting -port "$PANEL_PORT"
x-ui setting -webBasePath "$PANEL_PATH"
x-ui setting -ip 127.0.0.1

systemctl restart x-ui

ufw allow 80/tcp
ufw allow 443/tcp
ufw allow OpenSSH
ufw --force enable

echo "完成: https://$DOMAIN/$PANEL_PATH/"
