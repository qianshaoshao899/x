#!/bin/bash

# =================================================================
# 项目: 3x-ui + Nginx + SSL 安全集成部署脚本 (专家加固版)
# 特性: 自动证书申请, Nginx 限流防护, Fail2ban 联动, 127.0.0.1 闭环
# =================================================================

set -e

# 颜色代码
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# 1. 权限与组件预检
[ "$EUID" -ne 0 ] && echo -e "${RED}❌ 错误: 请用 root 运行此脚本。${NC}" && exit 1

echo -e "${GREEN}>>> 1. 正在初始化环境并安装必备组件...${NC}"
apt update && apt install -y curl socat nginx ufw fail2ban dnsutils tar

# 2. 交互式核心配置 (带回车默认值机制)
echo -e "${YELLOW}提示: 直接按回车将使用括号内的默认值。${NC}"

read -p "请输入您的域名 (默认: laizanbao.cc.cd): " INPUT_DOMAIN
DOMAIN=${INPUT_DOMAIN:-"laizanbao.cc.cd"}

DEFAULT_EMAIL="admin@$DOMAIN"
read -p "请输入联系邮箱 (默认: $DEFAULT_EMAIL): " INPUT_EMAIL
EMAIL=${INPUT_EMAIL:-"$DEFAULT_EMAIL"}

read -p "请输入面板监听端口 (默认: 33130): " INPUT_PORT
PANEL_PORT=${INPUT_PORT:-"33130"}

read -p "请输入面板访问路径 (默认: vQErspCQtsmxlhu7Qi): " INPUT_PATH
PANEL_PATH=${INPUT_PATH:-"vQErspCQtsmxlhu7Qi"}

SSL_DIR="/etc/nginx/ssl"

# 3. 域名解析校验 (防止 acme.sh 申请被封)
echo -e "${GREEN}>>> 2. 正在校验 DNS 解析状态...${NC}"
IP=$(curl -s ifconfig.me)
DOMAIN_IP=$(dig +short $DOMAIN | head -n1)

if [ -z "$DOMAIN_IP" ]; then
    echo -e "${RED}❌ 错误: 域名 $DOMAIN 未解析，请先在 DNS 处完成 A 记录解析。${NC}"
    exit 1
fi
echo -e "本机 IP: $IP | 解析 IP: $DOMAIN_IP"

# 4. SSL 证书处理 (Standalone 模式)
echo -e "${GREEN}>>> 3. 正在申请 ECC SSL 证书 (acme.sh)...${NC}"
systemctl stop nginx || true
[ -d "$HOME/.acme.sh" ] && rm -rf "$HOME/.acme.sh"
curl https://get.acme.sh | sh -s email=$EMAIL
source ~/.bashrc
ACME="$HOME/.acme.sh/acme.sh"

$ACME --issue -d $DOMAIN --standalone --ecc --force

mkdir -p $SSL_DIR
$ACME --install-cert -d $DOMAIN --ecc \
  --key-file       $SSL_DIR/panel.key  \
  --fullchain-file $SSL_DIR/panel.crt
chmod -R 644 $SSL_DIR/

# 5. Nginx 高级反代配置 (含安全加固)
echo -e "${GREEN}>>> 4. 正在注入 Nginx 防御性配置...${NC}"
cat <<EOF > /etc/nginx/conf.d/panel.conf
# 定义限流区域，防止面板被爆破 (每秒允许10个请求)
limit_req_zone \$binary_remote_addr zone=panel_limit:10m rate=10r/s;

server {
    listen 80;
    server_name $DOMAIN;
    return 301 https://\$host\$request_uri;
}

server {
    listen 443 ssl http2;
    server_name $DOMAIN;

    ssl_certificate $SSL_DIR/panel.crt;
    ssl_certificate_key $SSL_DIR/panel.key;
    
    # 强制现代加密协议
    ssl_protocols TLSv1.2 TLSv1.3;
    server_tokens off;

    # 安全响应头
    add_header X-Frame-Options SAMEORIGIN;
    add_header X-Content-Type-Options nosniff;

    location / {
        limit_req zone=panel_limit burst=20 nodelay;
        
        proxy_pass http://127.0.0.1:$PANEL_PORT;
        proxy_redirect off;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        
        # WebSocket 支持 (核心转发)
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
EOF

nginx -t && systemctl restart nginx

# 6. 3x-ui 安装与闭环加固
echo -e "${GREEN}>>> 5. 正在静默安装 3x-ui 并锁定本地监听...${NC}"
bash <(curl -Ls https://raw.githubusercontent.com/mhsanaei/3x-ui/master/install.sh) <<EOF
y
EOF

# 核心安全逻辑：强制面板仅监听 127.0.0.1，彻底断绝公网端口直连
x-ui setting -reset -port $PANEL_PORT -webbasepath $PANEL_PATH
x-ui setting -ip 127.0.0.1 
systemctl restart x-ui

# 7. 防火墙策略
echo -e "${GREEN}>>> 6. 正在配置并激活 UFW 防火墙...${NC}"
ufw allow 80/tcp
ufw allow 443/tcp
ufw allow 22/tcp
ufw --force enable

echo -e "${GREEN}====================================================${NC}"
echo -e "🚀 ${GREEN}全自动加固部署圆满完成！${NC}"
echo -e "访问链接: ${YELLOW}https://$DOMAIN/$PANEL_PATH${NC}"
echo -e "默认凭据: admin / admin"
echo -e "----------------------------------------------------"
echo -e "📋 ${YELLOW}专家建议的后续操作：${NC}"
echo -e "1. 进入面板后立即修改默认用户名与密码。"
echo -e "2. Cloudflare SSL/TLS 设置为 ${GREEN}Full (Strict)${NC}。"
echo -e "3. 开启 Cloudflare 的“小黄云”代理以隐藏服务器真 IP。"
echo -e "${GREEN}====================================================${NC}"
