#!/bin/bash
set -e

# ===== 颜色 =====
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${GREEN}=== 3x-ui + Nginx 一键部署（修复版） ===${NC}"

# ===== Root 检查 =====
[ "$EUID" -ne 0 ] && echo -e "${RED}请用 root 运行${NC}" && exit 1

# ===== 输入函数 =====
input_default() {
    local prompt="$1"
    local default="$2"
    local input

    while true; do
        read -p "$(echo -e ${YELLOW}$prompt${NC} [默认: $default]: )" input
        input=${input:-$default}

        [[ "$input" =~ \  ]] && echo -e "${RED}不能有空格${NC}" && continue

        echo "$input"
        return
    done
}

input_domain() {
    local domain
    while true; do
        read -p "$(echo -e ${YELLOW}请输入域名${NC}: )" domain
        [ -z "$domain" ] && domain="example.com"

        [[ "$domain" =~ \  ]] && echo -e "${RED}域名不能有空格${NC}" && continue

        if [[ ! "$domain" =~ ^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$ ]]; then
            echo -e "${RED}域名格式错误${NC}"
            continue
        fi

        echo "$domain"
        return
    done
}

input_port() {
    local port
    while true; do
        read -p "$(echo -e ${YELLOW}端口(10000-65535)${NC} [默认33130]: )" port
        port=${port:-33130}

        if ! [[ "$port" =~ ^[0-9]+$ ]] || [ "$port" -lt 10000 ] || [ "$port" -gt 65535 ]; then
            echo -e "${RED}端口不合法${NC}"
            continue
        fi

        echo "$port"
        return
    done
}

# ===== 输入 =====
DOMAIN=$(input_domain)
EMAIL=$(input_default "邮箱" "admin@$DOMAIN")
PANEL_PORT=$(input_port)
PANEL_PATH=$(input_default "路径(留空自动生成)" "")

[ -z "$PANEL_PATH" ] && PANEL_PATH=$(openssl rand -hex 8)

USERNAME=$(input_default "用户名" "admin")
PASSWORD=$(input_default "密码" "123456")

SSL_DIR="/etc/nginx/ssl"

echo -e "\n${GREEN}确认配置：${NC}"
echo "域名: $DOMAIN"
echo "端口: $PANEL_PORT"
echo "路径: $PANEL_PATH"

read -p "继续? (y/n): " CONFIRM
[ "$CONFIRM" != "y" ] && exit 0

# ===== 安装依赖 =====
apt update
apt install -y curl socat nginx ufw dnsutils openssl

# ===== DNS 检测 =====
IP=$(curl -s ifconfig.me)
DOMAIN_IP=$(dig +short $DOMAIN | head -n1)

if [ "$IP" != "$DOMAIN_IP" ]; then
    echo -e "${RED}域名未解析到本机${NC}"
    exit 1
fi

# ===== acme =====
rm -rf ~/.acme.sh
curl https://get.acme.sh | sh -s email=$EMAIL
source ~/.bashrc
ACME="$HOME/.acme.sh/acme.sh"

systemctl stop nginx || true

$ACME --issue -d $DOMAIN --standalone --ecc --force

mkdir -p $SSL_DIR

$ACME --install-cert -d $DOMAIN --ecc \
--key-file $SSL_DIR/panel.key \
--fullchain-file $SSL_DIR/panel.crt \
--reloadcmd "systemctl reload nginx"

# ===== Nginx =====
cat > /etc/nginx/conf.d/panel.conf <<EOF
server {
    listen 80;
    server_name $DOMAIN;
    return 301 https://\$host\$request_uri;
}

server {
    listen 443 ssl http2;
    server_name $DOMAIN;

    ssl_certificate $SSL_DIR/panel.crt;
    ssl_certificate_key $SSL_DIR/panel.key;

    location /$PANEL_PATH/ {
        proxy_pass http://127.0.0.1:$PANEL_PORT/;

        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host \$host;
    }
}
EOF

nginx -t
systemctl start nginx

# ===== 安装 3x-ui =====
bash <(curl -Ls https://raw.githubusercontent.com/mhsanaei/3x-ui/master/install.sh) <<< "y"

# ===== 配置 =====
x-ui setting -reset
x-ui setting -username "$USERNAME"
x-ui setting -password "$PASSWORD"
x-ui setting -port "$PANEL_PORT"
x-ui setting -webBasePath "$PANEL_PATH"
x-ui setting -ip 127.0.0.1

systemctl restart x-ui

# ===== 防火墙 =====
ufw allow 80/tcp
ufw allow 443/tcp
ufw allow OpenSSH
ufw --force enable

echo -e "${GREEN}部署完成${NC}"
echo "https://$DOMAIN/$PANEL_PATH/"
