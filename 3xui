#!/bin/bash
set -e

# ===== 可改参数（不改也能用）=====
DOMAIN="example.com"
EMAIL="admin@$DOMAIN"
PANEL_PORT="33130"
PANEL_PATH="$(openssl rand -hex 8)"
USERNAME="admin"
PASSWORD="123456"
SSL_DIR="/etc/nginx/ssl"

echo "=== 3x-ui 自动部署 ==="

# root 检查
[ "$EUID" -ne 0 ] && echo "请用 root 运行" && exit 1

# 安装依赖
apt update
apt install -y curl socat nginx ufw dnsutils openssl

# DNS 检测
IP=$(curl -s ifconfig.me)
DOMAIN_IP=$(dig +short $DOMAIN | head -n1)

if [ "$IP" != "$DOMAIN_IP" ]; then
    echo "域名未解析到本机"
    exit 1
fi

# Cloudflare 检测
if curl -sI http://$DOMAIN | grep -qi cloudflare; then
    echo "检测到 Cloudflare，请关闭小黄云再运行"
    exit 1
fi

# 安装 acme
rm -rf ~/.acme.sh
curl https://get.acme.sh | sh -s email=$EMAIL
ACME="$HOME/.acme.sh/acme.sh"

systemctl stop nginx || true

# 申请证书
$ACME --issue -d $DOMAIN --standalone --ecc --force

mkdir -p $SSL_DIR

$ACME --install-cert -d $DOMAIN --ecc \
--key-file $SSL_DIR/panel.key \
--fullchain-file $SSL_DIR/panel.crt

# Nginx 配置
cat > /etc/nginx/conf.d/panel.conf <<EOF
server {
    listen 80;
    server_name $DOMAIN;
    return 301 https://\$host\$request_uri;
}

server {
    listen 443 ssl http2;
    server_name $DOMAIN;

    ssl_certificate $SSL_DIR/panel.crt;
    ssl_certificate_key $SSL_DIR/panel.key;

    location /$PANEL_PATH/ {
        proxy_pass http://127.0.0.1:$PANEL_PORT/;
        proxy_set_header Host \$host;
    }
}
EOF

nginx -t && systemctl start nginx

# 安装 3x-ui
bash <(curl -Ls https://raw.githubusercontent.com/mhsanaei/3x-ui/master/install.sh) <<< "y"

# 配置面板
x-ui setting -reset
x-ui setting -username "$USERNAME"
x-ui setting -password "$PASSWORD"
x-ui setting -port "$PANEL_PORT"
x-ui setting -webBasePath "$PANEL_PATH"
x-ui setting -ip 127.0.0.1

systemctl restart x-ui

# 防火墙
ufw allow 80/tcp
ufw allow 443/tcp
ufw allow OpenSSH
ufw --force enable

echo "=================================="
echo "完成:"
echo "https://$DOMAIN/$PANEL_PATH/"
echo "账号: $USERNAME"
echo "密码: $PASSWORD"
echo "=================================="
